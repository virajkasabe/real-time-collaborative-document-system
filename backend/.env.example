# =================================================================
#  REALTIME COLLABORATIVE DOCUMENT SYSTEM (CollabDocs) - Backend ENV
# =================================================================

# Port and Environment
NODE_ENV="development"
PORT=5000
MONGODB_URI="mongodb://localhost:27017/rtcds"
APP_NAME="rtcds"
REDIS_URI="redis://localhost:6379"
DEFAULT_ROUTE="/rtcds/api/v1"

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173
BACKEND_URI=http://localhost:5000/api/v1/rtcds
RESET_PASSWORD_URL=http://localhost:5000/api/v1/rtcds/auth/reset-password

# Token Secrets and Expiry times
ACCESS_TOKEN_SECRET="your_access_token_secret_here"
REFRESH_TOKEN_SECRET="your_refresh_token_secret_here"
ACCESS_TOKEN_EXPIRY="1d"
REFRESH_TOKEN_EXPIRY="15d"

# Cloudinary Credentials (Optional - for avatars/media upload)
CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Brevo SMTP Configuration (Optional - for verification emails)
BREVO_API_KEY="your_brevo_api_key"
BREVO_SENDER_NAME="CollabDocs Team"
BREVO_SENDER_EMAIL="noreply@collabdocs.io"

# Google Auth Credentials (Optional - for OAuth login)
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/v1/rtcds/auth/callback/google"
